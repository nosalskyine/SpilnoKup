generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// — — — КОРИСТУВАЧІ — — —

model User {
  id                   String    @id @default(uuid())
  displayId            String?   @unique
  phoneEncrypted       String?
  phoneHash            String?   @unique
  emailEncrypted       String?
  emailHash            String?   @unique
  name                 String?
  avatarUrl            String?
  city                 String?
  role                 Role      @default(BUYER)
  isActive             Boolean   @default(true)
  isVerified           Boolean   @default(false)
  isBlocked            Boolean   @default(false)
  blockedReason        String?
  failedLoginAttempts  Int       @default(0)
  lockedUntil          DateTime?
  lastSeenAt           DateTime?
  deletedAt            DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  wallet           Wallet?
  deals            Deal[]           @relation("SellerDeals")
  buyerOrders      Order[]          @relation("BuyerOrders")
  sessions         UserSession[]
  fopProfile       FopProfile?
  websocketEvents      WebsocketEvent[]
  consentLogs          ConsentLog[]
  reviews              Review[]
  buyerConversations   Conversation[]   @relation("BuyerConversations")
  sellerConversations  Conversation[]   @relation("SellerConversations")
  sentMessages         Message[]

  @@map("users")
}

enum Role {
  BUYER
  SELLER
  ADMIN
}

// — — — СЕСІЇ — — —

model UserSession {
  id               String   @id @default(uuid())
  userId           String
  refreshTokenHash String   @unique
  deviceType       String?
  deviceName       String?
  ipAddress        String?
  expiresAt        DateTime
  lastActiveAt     DateTime @default(now())
  createdAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_sessions")
}

// — — — ВЕРИФІКАЦІЯ ТЕЛЕФОНУ — — —

model PhoneVerification {
  id          String    @id @default(uuid())
  phone       String
  otpHash     String
  attempts    Int       @default(0)
  maxAttempts Int       @default(3)
  expiresAt   DateTime
  isUsed      Boolean   @default(false)
  usedAt      DateTime?
  ipAddress   String?
  createdAt   DateTime  @default(now())

  @@index([phone])
  @@map("phone_verifications")
}

// — — — ФОП ПРОФІЛЬ — — —

model FopProfile {
  id           String    @id @default(uuid())
  userId       String    @unique
  fopName      String
  ipn          String
  iban         String
  bankName     String
  fopGroup     String
  taxRate      String?
  verified     Boolean   @default(false)
  verifiedAt   DateTime?
  diiaVerified Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@map("fop_profiles")
}

// — — — ГАМАНЕЦЬ — — —

model Wallet {
  id               String   @id @default(uuid())
  userId           String   @unique
  availableBalance Decimal  @default(0) @db.Decimal(12, 2)
  heldBalance      Decimal  @default(0) @db.Decimal(12, 2)
  totalEarned      Decimal  @default(0) @db.Decimal(12, 2)
  totalWithdrawn   Decimal  @default(0) @db.Decimal(12, 2)
  currency         String   @default("UAH")
  updatedAt        DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id])
  transactions Transaction[]
  withdrawals  Withdrawal[]

  @@map("wallets")
}

// — — — ТРАНЗАКЦІЇ — — —

model Transaction {
  id              String          @id @default(uuid())
  walletId        String
  orderId         String?
  type            TransactionType
  amount          Decimal         @db.Decimal(12, 2)
  commission      Decimal         @default(0) @db.Decimal(12, 2)
  netAmount       Decimal         @db.Decimal(12, 2)
  balanceBefore   Decimal         @db.Decimal(12, 2)
  balanceAfter    Decimal         @db.Decimal(12, 2)
  liqpayPaymentId String?
  description     String?
  status          String          @default("completed")
  createdAt       DateTime        @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id])

  @@index([walletId, createdAt])
  @@map("transactions")
}

enum TransactionType {
  PAYMENT_HOLD
  PAYMENT_RELEASE
  COMMISSION
  WITHDRAWAL
  REFUND
}

// — — — ВИВЕДЕННЯ КОШТІВ — — —

model Withdrawal {
  id            String    @id @default(uuid())
  walletId      String
  sellerId      String
  amount        Decimal   @db.Decimal(12, 2)
  fee           Decimal   @db.Decimal(12, 2)
  netAmount     Decimal   @db.Decimal(12, 2)
  iban          String
  bankName      String
  recipientName String
  status        String    @default("pending")
  externalId    String?
  processedAt   DateTime?
  createdAt     DateTime  @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id])

  @@index([sellerId, status])
  @@map("withdrawals")
}

// — — — ТОВАРИ / ГРУПОВІ ПОКУПКИ — — —

model Deal {
  id          String     @id @default(uuid())
  sellerId    String
  title       String
  description String?
  category    String
  retailPrice Decimal    @db.Decimal(12, 2)
  groupPrice  Decimal    @db.Decimal(12, 2)
  unit        String
  minQty      Int        @default(1)
  maxQty      Int        @default(100)
  needed      Int
  joined      Int        @default(0)
  deadline    DateTime
  status      DealStatus @default(ACTIVE)
  images      String[]
  tags        String[]
  isHot       Boolean    @default(false)
  isNew       Boolean    @default(true)
  city        String?
  views       Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  seller  User      @relation("SellerDeals", fields: [sellerId], references: [id])
  orders        Order[]
  reviews       Review[]
  auction       Auction?
  conversations Conversation[]

  @@index([sellerId, status])
  @@index([category, status])
  @@index([city, status])
  @@index([deadline, status])
  @@map("deals")
}

enum DealStatus {
  ACTIVE
  COMPLETED
  CANCELLED
  EXPIRED
}

// — — — ЗАМОВЛЕННЯ — — —

model Order {
  id            String      @id @default(uuid())
  dealId        String
  buyerId       String
  quantity      Int
  amount        Decimal     @db.Decimal(12, 2)
  status        OrderStatus @default(PENDING)
  refundReason  String?
  completedAt   DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  deal    Deal     @relation(fields: [dealId], references: [id])
  buyer   User     @relation("BuyerOrders", fields: [buyerId], references: [id])
  payment Payment?
  qrToken QrToken?

  @@index([dealId, status])
  @@index([buyerId, status])
  @@map("orders")
}

enum OrderStatus {
  PENDING
  PAID
  COMPLETED
  REFUNDED
  CANCELLED
}

// — — — ПЛАТЕЖІ — — —

model Payment {
  id              String    @id @default(uuid())
  orderId         String    @unique
  buyerId         String
  amount          Decimal   @db.Decimal(12, 2)
  currency        String    @default("UAH")
  liqpayOrderId   String?   @unique
  liqpayPaymentId String?
  liqpayStatus    String?
  idempotencyKey  String    @unique
  status          String    @default("pending")
  paidAt          DateTime?
  createdAt       DateTime  @default(now())

  order Order @relation(fields: [orderId], references: [id])

  @@index([buyerId, status])
  @@map("payments")
}

// — — — QR ТОКЕНИ — — —

model QrToken {
  id        String    @id @default(uuid())
  orderId   String    @unique
  token     String    @unique
  expiresAt DateTime
  isUsed    Boolean   @default(false)
  usedAt    DateTime?
  usedBy    String?
  createdAt DateTime  @default(now())

  order Order @relation(fields: [orderId], references: [id])

  @@index([token, isUsed])
  @@map("qr_tokens")
}

// — — — WEBSOCKET ПОДІЇ — — —

model WebsocketEvent {
  id          String    @id @default(uuid())
  userId      String
  eventType   String
  payload     Json
  delivered   Boolean   @default(false)
  deliveredAt DateTime?
  retryCount  Int       @default(0)
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, delivered])
  @@map("websocket_events")
}

// — — — ВІДГУКИ — — —

model Review {
  id        String   @id @default(uuid())
  dealId    String
  userId    String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  deal Deal @relation(fields: [dealId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@unique([dealId, userId])
  @@index([dealId])
  @@map("reviews")
}

// — — — ТОЧКИ ВИДАЧІ — — —

model PickupPoint {
  id        String   @id @default(uuid())
  name      String
  address   String
  city      String
  lat       Float?
  lng       Float?
  type      String   @default("seller")
  isActive  Boolean  @default(true)
  workHours String?
  phone     String?
  sellerId  String?
  createdAt DateTime @default(now())

  @@index([city, isActive])
  @@map("pickup_points")
}

// — — — ЗГОДА НА ОБРОБКУ ДАНИХ — — —

model ConsentLog {
  id          String   @id @default(uuid())
  userId      String
  consentType String
  granted     Boolean
  ipAddress   String?
  recordedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("consent_logs")
}

// — — — АУКЦІОН — — —

model Auction {
  id           String   @id @default(uuid())
  dealId       String   @unique
  startPrice   Decimal  @db.Decimal(12, 2)
  currentPrice Decimal  @db.Decimal(12, 2)
  minStep      Decimal  @db.Decimal(12, 2)
  endsAt       DateTime
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  deal Deal @relation(fields: [dealId], references: [id])

  @@map("auctions")
}

// — — — ЧАТ — — —

model Conversation {
  id            String    @id @default(uuid())
  dealId        String?
  buyerId       String
  sellerId      String
  lastMessageAt DateTime  @default(now())
  createdAt     DateTime  @default(now())

  buyer    User      @relation("BuyerConversations", fields: [buyerId], references: [id])
  seller   User      @relation("SellerConversations", fields: [sellerId], references: [id])
  deal     Deal?     @relation(fields: [dealId], references: [id])
  messages Message[]

  @@unique([buyerId, sellerId, dealId])
  @@map("conversations")
}

model Message {
  id             String   @id @default(uuid())
  conversationId String
  senderId       String
  text           String
  isRead         Boolean  @default(false)
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id])
  sender       User         @relation(fields: [senderId], references: [id])

  @@index([conversationId, createdAt])
  @@map("messages")
}
